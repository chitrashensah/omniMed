# ── AI provider keys ──────────────────────────────────────
# Add only the providers you intend to serve. A Gemini key is the
# minimum needed for the free tier and the consensus synthesis step.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
COHERE_API_KEY=

# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_key
# Service-role key — required for server-side writes (usage logs,
# documents, session turns). Backend-only; never expose to the client.
SUPABASE_SERVICE_KEY=your_service_role_key

# ── Admin ─────────────────────────────────────────────────
# The single admin account: unlimited model access + admin dashboard.
# Must match VITE_ADMIN_EMAIL (frontend) and the email used in supabase_setup.sql.
ADMIN_EMAIL=you@example.com
